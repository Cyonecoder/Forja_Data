# ============================================================
# FORJA Data Pipeline
# Copier ce fichier en .env et remplir les valeurs réelles
# ============================================================

# PostgreSQL SNRT (read-only)
POSTGRES_HOST=169.255.179.24          # ou host interne si différent
POSTGRES_PORT=5432
POSTGRES_DB=snrt_stats
POSTGRES_USER=snrt_readonly
POSTGRES_PASSWORD=CHANGE_ME_SECRET

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_SNRT=snrt.actions
KAFKA_TOPIC_GA4=ga4.events

# MinIO (Data Lake local = S3-compatible)
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=forja-datalake

# Schema Registry
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Google Analytics 4
GA4_PROPERTY_ID=CHANGE_ME_GA4_PROPERTY_ID
